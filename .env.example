# CloudTrim environment (copy to .env). All vars are prefixed CLOUDTRIM_.
CLOUDTRIM_ENVIRONMENT=development

# LLM provider (Week 1 AI explainer) — leave blank until wired up.
# CLOUDTRIM_LLM_API_KEY=

# Async queue + persistence (Week 3):
# CLOUDTRIM_REDIS_URL=redis://localhost:6379/0
# CLOUDTRIM_DATABASE_URL=postgresql+psycopg://cloudtrim:cloudtrim@localhost:5432/cloudtrim

# GitHub App (Week 4) — webhook secret + a token (App installation token or PAT):
# CLOUDTRIM_GITHUB_WEBHOOK_SECRET=
# CLOUDTRIM_GITHUB_TOKEN=

# Production hardening (Week 5) — all opt-in:
# CLOUDTRIM_API_KEYS=key1,key2          # enable API-key auth
# CLOUDTRIM_RATE_LIMIT_PER_MINUTE=120   # enable per-client rate limiting
