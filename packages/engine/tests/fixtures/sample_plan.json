{
  "format_version": "1.0",
  "terraform_version": "1.9.0",
  "values": {
    "root_module": {
      "resources": [
        {
          "address": "aws_instance.web",
          "type": "aws_instance",
          "name": "web",
          "values": {
            "instance_type": "t3.large",
            "region": "us-east-1",
            "tags": { "env": "prod", "Name": "web" }
          }
        },
        {
          "address": "aws_db_instance.main",
          "type": "aws_db_instance",
          "name": "main",
          "values": { "instance_class": "db.t3.medium" }
        }
      ],
      "child_modules": [
        {
          "address": "module.storage",
          "resources": [
            {
              "address": "module.storage.aws_s3_bucket.logs",
              "type": "aws_s3_bucket",
              "name": "logs",
              "values": { "bucket": "my-logs-bucket" }
            }
          ]
        }
      ]
    }
  }
}
