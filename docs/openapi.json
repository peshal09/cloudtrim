        "description": "Which path produced a finding's explanation. Emitted for UI + CI assertions."
      },
      "Finding": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id"
          },
          "analysis_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Analysis Id"
          },
          "resource_id": {
            "type": "string",
            "title": "Resource Id"
          },
          "detector": {
            "type": "string",
            "title": "Detector"
          },
          "title": {
            "type": "string",
            "title": "Title"
          },
          "severity": {
            "$ref": "#/components/schemas/Severity"
          },
          "risk": {
            "$ref": "#/components/schemas/Risk",
            "default": "medium"
          },
          "current_cost": {
            "type": "number",
            "title": "Current Cost",
            "default": 0.0
          },
          "projected_cost": {
            "type": "number",
            "title": "Projected Cost",
            "default": 0.0
          },
          "monthly_savings": {
            "type": "number",
            "title": "Monthly Savings",
            "default": 0.0
          },
          "evidence": {
            "additionalProperties": true,
            "type": "object",
            "title": "Evidence"
          },
          "remediation_diff": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Remediation Diff"
          },
          "confidence": {
            "type": "number",
            "title": "Confidence",
            "default": 1.0
          },
          "explanation": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Explanation"
          },
          "explanation_source": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/ExplanationSource"
              },
              {
                "type": "null"
              }
            ]
          }
        },
        "type": "object",
        "required": [
          "resource_id",
          "detector",
          "title",
          "severity"
        ],
        "title": "Finding",
        "description": "A detected waste/anti-pattern on a resource, priced and risk-scored.\n\nEvery dollar figure is set by the deterministic engine (pricing). The\n`explanation`/`explanation_source` fields are populated last by the AI layer,\nwhose output is validated against `monthly_savings` regardless of source."
      },
